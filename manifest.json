{
  "manifest_version": 3,
  "name": "Download Bell",
  "version": "1.1.1",
  "description": "Sound notifications for download completion and failure. Custom sounds supported.",
  "permissions": ["downloads", "storage", "offscreen"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Download Bell"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
